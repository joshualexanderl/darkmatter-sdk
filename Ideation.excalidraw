    {
      "id": "PewItwilZf0m5a53UIZiL",
      "type": "text",
      "x": 14046.354229671486,
      "y": -67.76641007389298,
      "width": 553.3324584960938,
      "height": 63.75,
      "angle": 0,
      "strokeColor": "#15803d",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3q",
      "roundness": null,
      "seed": 1831831673,
      "version": 6,
      "versionNonce": 910826231,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1774802862371,
      "link": null,
      "locked": false,
      "text": "Think of it like a USB port. Before USB, every device had its own\nweird cable. USB said: \"Everyone use THIS shape.\" Now everything\njust works together. That's what we're doing, but for AI agents.",
      "fontSize": 17,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Think of it like a USB port. Before USB, every device had its own\nweird cable. USB said: \"Everyone use THIS shape.\" Now everything\njust works together. That's what we're doing, but for AI agents.",
      "autoResize": true,
      "lineHeight": 1.25
    },
