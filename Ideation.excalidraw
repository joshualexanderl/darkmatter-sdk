    {
      "id": "y6fYrvOoRxvVUWSH8eQPZ",
      "type": "text",
      "x": -1582.3829120097027,
      "y": 311.77912006911833,
      "width": 612.4796142578125,
      "height": 60,
      "angle": 0,
      "strokeColor": "#2563eb",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
