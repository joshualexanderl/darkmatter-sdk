      "isDeleted": false,
      "boundElements": [],
      "updated": 1774802902900,
      "link": null,
      "locked": false,
      "text": "Problem: Hard to standardize new agents.\n\nSolution: A minimal SDK + contract that lets anyone\ncreate or register an agent in a standardized way.\nIt standardizes:\n    1) Agent Identity (metadata)\n    2) Run Interface\n    3) Tool Integration",
      "fontSize": 31.562248800530092,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Problem: Hard to standardize new agents.\n\nSolution: A minimal SDK + contract that lets anyone\ncreate or register an agent in a standardized way.\nIt standardizes:\n    1) Agent Identity (metadata)\n    2) Run Interface\n    3) Tool Integration",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "VxBaPRcduLscDOwmfG26q",
      "type": "text",
      "x": 269.9231022511167,
      "y": -3045.8341741101126,
      "width": 600.0666350975735,
      "height": 236.6922855066789,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0qV",
      "roundness": null,
      "seed": 1457515831,
      "version": 1406,
      "versionNonce": 1437488581,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774801818742,
      "link": null,
      "locked": false,
      "text": "Problem: Hard to standardize new agents.\n\nSolution: A minimal SDK + contract that lets anyone\ncreate or register an agent in a standardized way.\nIt standardizes:\n    1) Agent Identity (metadata)\n    2) Run Interface\n    3) Tool Integration",
      "fontSize": 23.669228550667885,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Problem: Hard to standardize new agents.\n\nSolution: A minimal SDK + contract that lets anyone\ncreate or register an agent in a standardized way.\nIt standardizes:\n    1) Agent Identity (metadata)\n    2) Run Interface\n    3) Tool Integration",
      "autoResize": true,
      "lineHeight": 1.25
    },
