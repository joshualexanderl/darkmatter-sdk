    {
      "id": "B5Qz5QGCxswZ4xVx5CXOR",
      "type": "text",
      "x": -4098.139368994118,
      "y": -2655.0710289812696,
      "width": 1209.459140373048,
      "height": 198.53772322890862,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0e",
      "roundness": null,
      "seed": 678706261,
      "version": 1254,
      "versionNonce": 815390967,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774802902900,
      "link": null,
      "locked": false,
      "text": "AI tool that helps studios optimize film revenue by connecting theatrical,\nstreaming, brand partnerships, and merchandise into one unified strategy.\nInstead of treating each stream separately, it analyzes content and audience\nto recommend how these revenue streams should work together to maximize\nimpact and earnings.",
      "fontSize": 31.766035716625357,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "AI tool that helps studios optimize film revenue by connecting theatrical, streaming, brand partnerships, and merchandise into one unified strategy. Instead of treating each stream separately, it analyzes content and audience to recommend how these revenue streams should work together to maximize impact and earnings.",
      "autoResize": false,
      "lineHeight": 1.25
    },
