    {
      "id": "TPW_S2HKPHSFV6xK6aFhL",
      "type": "text",
      "x": -3997.631753890635,
      "y": -1791.1356610494615,
      "width": 800.1719360351562,
      "height": 315.6224880053009,
      "angle": 0,
