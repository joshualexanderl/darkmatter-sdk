    {
      "id": "MOYKdC3wqDj18ph8cRgZD",
      "type": "text",
      "x": -1602.3226195478128,
      "y": -2142.922745883507,
      "width": 608.2763671875,
      "height": 42.5,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
