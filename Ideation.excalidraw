    {
      "id": "CoBb-mp129_rJZFjwvzbA",
      "type": "text",
      "x": -1602.3226195478128,
      "y": -532.9227458835071,
      "width": 616.6395263671875,
      "height": 100,
      "angle": 0,
      "strokeColor": "#15803d",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b6v",
      "roundness": null,
      "seed": 2098692697,
      "version": 6,
      "versionNonce": 477053847,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1774803379478,
      "link": null,
      "locked": false,
      "text": "Agents often need tools: a calculator, a web searcher, a database lookup.\nDarkMatter gives tools a standard plug shape so ANY agent can use ANY tool.\n\nLike how any USB device works in any USB port. You don't need a special\nport for your keyboard and a different one for your mouse.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Agents often need tools: a calculator, a web searcher, a database lookup.\nDarkMatter gives tools a standard plug shape so ANY agent can use ANY tool.\n\nLike how any USB device works in any USB port. You don't need a special\nport for your keyboard and a different one for your mouse.",
      "autoResize": true,
      "lineHeight": 1.25
    },
