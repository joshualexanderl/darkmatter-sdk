      "locked": false,
      "text": "\"I built an agent. To connect it\nto yours I need to rewrite a bunch\nof stuff. If we swap one, we start\nover.\"",
      "fontSize": 15,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\"I built an agent. To connect it\nto yours I need to rewrite a bunch\nof stuff. If we swap one, we start\nover.\"",
