      "updated": 1774803399110,
      "link": null,
      "locked": false,
      "text": "\"I built an agent. It follows the\nDarkMatter rules. Anyone can install\nit, run it, chain it with others, or\nswap it out. Just works.\"",
      "fontSize": 15,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\"I built an agent. It follows the\nDarkMatter rules. Anyone can install\nit, run it, chain it with others, or\nswap it out. Just works.\"",
      "autoResize": true,
      "lineHeight": 1.25
    },
