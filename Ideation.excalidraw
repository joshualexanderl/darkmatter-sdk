      "text": "DARKMATTER = THE USB STANDARD",
      "fontSize": 24,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "DARKMATTER = THE USB STANDARD",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "si5F9niltiV2S86w6-aX9",
      "type": "text",
      "x": -1585.8768576631996,
      "y": -2314.5767724391644,
      "width": 578.3355102539062,
      "height": 60,
      "angle": 0,
      "strokeColor": "#6d28d9",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4y",
      "roundness": null,
      "seed": 122798711,
      "version": 155,
      "versionNonce": 257988119,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774802992139,
      "link": null,
      "locked": false,
      "text": "One standard so agents built by different people, in different frameworks,\ncan be installed, discovered, run, and combined without glue code.\nTreat agents like packages you npm install, not codebases you fork.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "One standard so agents built by different people, in different frameworks,\ncan be installed, discovered, run, and combined without glue code.\nTreat agents like packages you npm install, not codebases you fork.",
      "autoResize": true,
      "lineHeight": 1.25
    },
