    {
      "id": "8tLWg_ROHSN9yr1YXVW-x",
      "type": "text",
      "x": -1580.813904037505,
      "y": 740.6969229704277,
      "width": 616.6395263671875,
      "height": 100,
      "angle": 0,
      "strokeColor": "#15803d",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
