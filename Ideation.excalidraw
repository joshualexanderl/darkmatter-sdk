      "versionNonce": 177206583,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774803415890,
      "link": null,
      "locked": false,
      "text": "Every agent fills out a simple card: name, version, what it does, who made it.\nLike a name tag at a conference. So anyone can find it and know what it does\nbefore they use it.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Every agent fills out a simple card: name, version, what it does, who made it.\nLike a name tag at a conference. So anyone can find it and know what it does\nbefore they use it.",
      "autoResize": true,
      "lineHeight": 1.25
    },
