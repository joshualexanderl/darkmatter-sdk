    },
    {
      "id": "WJdqdW121oCUmbXDPk88z",
      "type": "text",
      "x": -1582.3829120097027,
      "y": 491.77912006911833,
      "width": 617.2154541015625,
      "height": 120,
      "angle": 0,
      "strokeColor": "#6d28d9",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b8Q",
      "roundness": null,
      "seed": 1709911641,
      "version": 188,
      "versionNonce": 2095734775,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774803415890,
      "link": null,
      "locked": false,
      "text": "Every agent has ONE way to be called: you send input in, you get a result out.\nAlways the same shape. Always predictable.\n\nImagine every restaurant in the world used the same ordering system.\nYou walk up, place your order the same way, get your receipt the same way.\nDoesn't matter if it's sushi or tacos. Same process.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Every agent has ONE way to be called: you send input in, you get a result out.\nAlways the same shape. Always predictable.\n\nImagine every restaurant in the world used the same ordering system.\nYou walk up, place your order the same way, get your receipt the same way.\nDoesn't matter if it's sushi or tacos. Same process.",
      "autoResize": true,
      "lineHeight": 1.25
    },
