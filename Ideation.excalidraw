      "boundElements": [],
      "updated": 1774803379478,
      "link": null,
      "locked": false,
      "text": "Now you want to serve a meal that uses dishes from ALL THREE kitchens?\nYou have to rebuild the plates, translate the recipes, rewire the stoves.\nThat's the \"glue code.\" And every time you swap a kitchen, you start over.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Now you want to serve a meal that uses dishes from ALL THREE kitchens?\nYou have to rebuild the plates, translate the recipes, rewire the stoves.\nThat's the \"glue code.\" And every time you swap a kitchen, you start over.",
      "autoResize": true,
      "lineHeight": 1.25
    },
