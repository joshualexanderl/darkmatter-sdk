      "boundElements": [],
      "updated": 1774802992139,
      "link": null,
      "locked": false,
      "text": "Each has its own\nrun command\n\nOnly works in its\nown framework\n\nCombining them =\ncustom glue code",
      "fontSize": 14,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Each has its own\nrun command\n\nOnly works in its\nown framework\n\nCombining them =\ncustom glue code",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "teQ51i5At05Zs5Bpgf3Xr",
      "type": "text",
      "x": -1565.8768576631996,
      "y": -2461.5767724391644,
      "width": 493.66253662109375,
      "height": 21.25,
      "angle": 0,
      "strokeColor": "#b91c1c",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4u",
      "roundness": null,
      "seed": 514586103,
      "version": 155,
      "versionNonce": 66689431,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774802992139,
      "link": null,
      "locked": false,
      "text": "It's like every USB device needing its own proprietary port.",
      "fontSize": 17,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It's like every USB device needing its own proprietary port.",
