    {
      "id": "kV2lQBowWAkH3Zo3v83qC",
      "type": "text",
      "x": -1581.5415599086691,
      "y": -420.37930735011923,
      "width": 589.6155395507812,
      "height": 60,
      "angle": 0,
      "strokeColor": "#b91c1c",
      "backgroundColor": "transparent",
