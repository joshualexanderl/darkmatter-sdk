      "isDeleted": false,
      "boundElements": [],
      "updated": 1774803387277,
      "link": null,
      "locked": false,
      "text": "An agent is a little program that does a job for you using AI.\nYou give it a task, it figures out how to do it, and gives you the answer.",
      "fontSize": 17,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "An agent is a little program that does a job for you using AI.\nYou give it a task, it figures out how to do it, and gives you the answer.",
      "autoResize": true,
      "lineHeight": 1.25
    },
